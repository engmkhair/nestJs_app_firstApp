
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}
enum Role{
  Admin
  Owner
  customer
}
 model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String
  password  String
  role Role
  createdAt DateTime @default(now())
  shops Shop[]
}

model InventoryProduct {
 id        Int      @id @default(autoincrement())
 name      String
 tradePrice     Int
 quantity Int
 createdAt DateTime @default(now())
 products Product[]
}

model Product {
 id        Int      @id @default(autoincrement())
 name      String
 price     Int
 quantity Int
 createdAt DateTime @default(now())
 inventoryProductId Int
 inventoryProduct InventoryProduct @relation(fields: [inventoryProductId],references: [id])
 shopId Int
 shop Shop @relation(fields: [shopId],references: [id])
}

model Shop{
  id        Int      @id @default(autoincrement())
  name      String
  location  String
  ownerId Int?
  Owner User? @relation(fields: [ownerId], references: [id],onDelete: SetNull)
  createdAt DateTime @default(now())
  products Product[]
}

